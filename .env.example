# =============================================================================
# Enquesta DQ Agent — environment variables template
# =============================================================================
# Copy this file to .env and fill in real values.
# The .env file is gitignored — secrets stay out of version control.
#
#   cp .env.example .env
#   # then edit .env with your real SMTP credentials
# =============================================================================

# SMTP for flagged-row email notifications
# For Gmail, use an "App Password" (not your regular password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-sender@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_ADDRESS=your-sender@gmail.com

# Optional: override Ollama base URL (default is localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
